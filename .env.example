# External MinIO Configuration
MINIO_ENDPOINT=http://your-minio-server:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_STAGING_BUCKET=warehouse-staging
MINIO_SANDBOX_BUCKET=sandbox-warehouse
MINIO_SSL_ENABLED=true

# PostgreSQL Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

REMOTE_TRINO_HOST=trino72.pusilkom.com
REMOTE_TRINO_PORT=443
REMOTE_TRINO_USERNAME=admin
REMOTE_TRINO_PASSWORD=admin123

# Trino Configuration
TRINO_HOST=trino-cluster-trino
TRINO_PORT=8080  # HTTP Port behind load balancer
TRINO_USERNAME=admin
TRINO_PASSWORD=admin123
TRINO_DOMAIN=trino.yourdomain.com
METASTORE_PORT=9083
METASTORE_STAGING_PORT=9084
METASTORE_SANDBOX_PORT=9085
# Let's Encrypt Configuration
ACME_EMAIL=your-email@domain.com

# Additional Trino Users (format: user:password,user:password)
# Leave empty for no additional users
ADDITIONAL_USERS=isacitra:isasigma,customer:customer123