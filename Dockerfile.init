FROM python:3.11-slim

# Install required packages
RUN apt-get update && apt-get install -y \
    curl \
    apache2-utils \
    dos2unix \
    && rm -rf /var/lib/apt/lists/*

# Copy generator scripts
COPY scripts/generate_hive_properties.py /app/generate_hive_properties.py
COPY scripts/init.sh /app/init.sh

# Convert line endings and make executable (multiplatform support)
RUN dos2unix /app/init.sh && chmod +x /app/init.sh

# Create working directory
WORKDIR /app

# Set entrypoint
ENTRYPOINT ["/app/init.sh"]
